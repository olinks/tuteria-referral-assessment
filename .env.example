# ---- Supabase (BaaS) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Used by API routes to bypass RLS for reads/writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Resend (email transport) ----
RESEND_API_KEY=re_your_key
# Use a verified sender. onboarding@resend.dev works for a new account,
# but only delivers to your own signup email until a domain is verified.
MAIL_FROM=Medbuddy <onboarding@resend.dev>

# ---- App ----
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
